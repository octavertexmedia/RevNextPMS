# =============================================================================
# Channel Manager — bootstrap .env only
# =============================================================================
# App secrets (SECRET_KEY, Razorpay, OIDC clients, ALLOWED_HOSTS, …) live in
# OpenBao at secrets.revnext.in — NOT in this file once OPENBAO_ENABLED=true.
#
# auth.revnext.in is the OIDC IdP (SSO only). It does not store app env.
#
# Postgres container still needs DB_* here at `docker compose up` time.
# Keep DB_PASSWORD in sync with OpenBao path …/database.
# =============================================================================

CHANNEL_MANAGER_NGINX_TLS=0

# --- OpenBao bootstrap (required in production) ---
OPENBAO_ENABLED=true
OPENBAO_REQUIRED=true
# Same-host Docker → host-published OpenBao (~/revnext-secrets :8200)
OPENBAO_ADDR=http://172.17.0.1:8200
# Or public edge: OPENBAO_ADDR=https://secrets.revnext.in
# Prefer AppRole (not root token) for the app:
OPENBAO_ROLE_ID=
OPENBAO_SECRET_ID=
# Temporary bootstrap only — remove after AppRole is working:
# OPENBAO_TOKEN=
OPENBAO_MOUNT_POINT=secret
OPENBAO_SECRET_PATH=revnext/channel-manager
OPENBAO_ENVIRONMENT=production
OPENBAO_OVERWRITE_ENV=true
OPENBAO_TLS_VERIFY=false
OPENBAO_ALLOW_ANY_KEY=false

DEBUG=False

# --- Postgres container (compose) — also store under OpenBao database/ group ---
DB_NAME=channel_manager
DB_USER=postgres
DB_PASSWORD=change-this-secure-password
DB_HOST=db
DB_PORT=5432

# Fallback only when OPENBAO_ENABLED=false (local/dev). In prod, set SECRET_KEY in OpenBao.
# SECRET_KEY=

# When OpenBao is disabled locally, you may set full env below (see git history / docs).
# Production: write keys via OpenBao UI/CLI under:
#   secret/data/revnext/channel-manager/production
#   secret/data/revnext/channel-manager/production/django|database|billing|oidc|…
#
# OIDC / suite (store under OpenBao oidc/ group):
#   OIDC_ENABLED=true
#   OIDC_OP_ISSUER=https://auth.revnext.in/realms/revnext
#   OIDC_RP_CLIENT_ID=… / OIDC_CLIENT_*_ID + _SECRET per product
#   ENTITLEMENTS_SERVICE_TOKEN=<shared with RevNextCMS REVNEXT_CM_ENTITLEMENTS_TOKEN>
#
# Hotel CMS is externally served (RevNextCMS). After migrate + seed_products:
#   python manage.py migrate products
#   python manage.py seed_products
