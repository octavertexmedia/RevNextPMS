# Django Configuration
SECRET_KEY=django-insecure-change-this-in-production
DEBUG=False
# All product + infra hosts (comma-separated). Include VPS IP if you hit by IP.
ALLOWED_HOSTS=revnext.in,www.revnext.in,channel-manager.revnext.in,booking.revnext.in,networks.revnext.in,pms.revnext.in,pos.revnext.in,cms.revnext.in,hotels.revnext.in,tours.revnext.in,secrets.revnext.in,auth.revnext.in,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://revnext.in,https://www.revnext.in,https://channel-manager.revnext.in,https://booking.revnext.in,https://networks.revnext.in,https://pms.revnext.in,https://pos.revnext.in,https://cms.revnext.in,https://hotels.revnext.in,https://tours.revnext.in,https://secrets.revnext.in,https://auth.revnext.in
CORS_ALLOWED_ORIGINS=https://revnext.in,https://www.revnext.in,https://channel-manager.revnext.in,https://booking.revnext.in,https://networks.revnext.in,https://pms.revnext.in,https://pos.revnext.in,https://cms.revnext.in,https://hotels.revnext.in,https://tours.revnext.in,http://localhost:3000,http://127.0.0.1:3000
SITE_URL=https://channel-manager.revnext.in
# Behind nginx TLS — keep True; /health/ is exempt for Docker healthchecks
SECURE_SSL_REDIRECT=True

# Database Configuration
DB_NAME=channel_manager
DB_USER=postgres
DB_PASSWORD=change-this-secure-password
DB_HOST=db
DB_PORT=5432

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Google Maps API (optional)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Environment
ENVIRONMENT=production

# SaaS billing gateway — choose ONE preferred: razorpay | payu
# (Can also switch at runtime via Constance BILLING_GATEWAY or POST /api/products/billing/prefer/)
BILLING_GATEWAY=razorpay

# Razorpay (platform RevNext account — subscription billing)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# PayU (platform RevNext account — subscription billing)
PAYU_MERCHANT_KEY=your_payu_merchant_key
PAYU_MERCHANT_SALT=your_payu_merchant_salt
PAYU_MODE=test

# ---------------------------------------------------------------------------
# OpenBao secrets manager (Apache-2.0 Vault fork)
# When OPENBAO_ENABLED=true, platform secrets are loaded from OpenBao KV v2
# and overlay .env values. Keep OPENBAO_* bootstrap vars in .env only.
# ---------------------------------------------------------------------------
OPENBAO_ENABLED=false
# In docker-compose.prod.yml web uses OPENBAO_ADDR=http://openbao:8200
# Public edge: https://secrets.revnext.in  |  Local: http://127.0.0.1:8200
OPENBAO_ADDR=http://openbao:8200
OPENBAO_TOKEN=dev-root-token
# Or AppRole (preferred in production):
# OPENBAO_ROLE_ID=
# OPENBAO_SECRET_ID=
OPENBAO_MOUNT_POINT=secret
OPENBAO_SECRET_PATH=revnext/channel-manager
OPENBAO_ENVIRONMENT=production
# Fail startup if OpenBao is unreachable (recommended when OPENBAO_ENABLED=true)
OPENBAO_REQUIRED=false
# Overlay values from OpenBao even when already set in .env
OPENBAO_OVERWRITE_ENV=true
OPENBAO_TLS_VERIFY=false

# OIDC IdP at auth.revnext.in (client secrets should live in OpenBao oidc/ group)
OIDC_ENABLED=false
OIDC_OP_ISSUER=https://auth.revnext.in
OIDC_RP_CLIENT_ID=
OIDC_RP_CLIENT_SECRET=
OIDC_RP_CALLBACK_URL=https://channel-manager.revnext.in/oidc/callback/
OIDC_RP_SCOPES=openid profile email

# Per-product OIDC relying-party clients (optional; fall back to OIDC_RP_*)
# booking.revnext.in
OIDC_CLIENT_BOOKING_ID=
OIDC_CLIENT_BOOKING_SECRET=
# networks.revnext.in
OIDC_CLIENT_NETWORKS_ID=
OIDC_CLIENT_NETWORKS_SECRET=
# other product hosts
OIDC_CLIENT_CHANNEL_MANAGER_ID=
OIDC_CLIENT_CHANNEL_MANAGER_SECRET=
OIDC_CLIENT_PMS_ID=
OIDC_CLIENT_PMS_SECRET=
OIDC_CLIENT_POS_ID=
OIDC_CLIENT_POS_SECRET=
OIDC_CLIENT_CMS_ID=
OIDC_CLIENT_CMS_SECRET=
OIDC_CLIENT_HOTELS_ID=
OIDC_CLIENT_HOTELS_SECRET=
OIDC_CLIENT_TOURS_ID=
OIDC_CLIENT_TOURS_SECRET=

# Entrypoint (Docker): seed product catalog on container start
SEED_ON_START=true
SEED_RBAC_ON_START=false
COLLECTSTATIC_ON_START=false
